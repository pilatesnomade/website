---
import Layout from "../layouts/layout.astro"
import TextImage from "../components/storyblok/TextImage.astro"
import Hero from "../components/storyblok/Hero.astro"
import BigText from "../components/storyblok/BigText.astro"
import CardsChoices from "../components/storyblok/CardsChoices.astro"
import Testimonials from "../components/storyblok/Testimonials.astro"
import Marquee from "../components/storyblok/Marquee.astro"
import Timeline from "../components/storyblok/Timeline.astro"

const year = new Date().getFullYear()
---

<Layout desc="pilates nomade page accueil" titre="titre accueil">
  <Hero />
  <TextImage />
  <BigText texture="1" sticker="semiround" position="right" />
  <BigText texture="2" sticker="star" position="left" />
  <BigText texture="3" sticker="arc" />
  <BigText texture="4" sticker="mandala" position="right" />
  <CardsChoices />
  <Testimonials />
  <Marquee />
  <Timeline />

  <footer>
    <p>
      &copy; {year} Pilates Nomade. Tout droits réservés.
    </p>
  </footer>
</Layout>

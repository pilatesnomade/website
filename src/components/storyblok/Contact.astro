---
import { Image, inferRemoteSize } from "astro:assets";
import { storyblokEditable } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import RichTextRenderer from "storyblok-rich-text-astro-renderer/RichTextRenderer.astro";
import Button from "./Button.astro";

const { blok } = Astro.props;

const posX = blok.image?.focus?.split(":")[0].split("x")[0] || "50";
const posY = blok.image?.focus?.split(":")[0].split("x")[1] || "50";
const { width, height } = await inferRemoteSize(blok.image?.filename);
const focalPointX = (parseInt(posX) / width) * 100;
const focalPointY = (parseInt(posY) / height) * 100;
---

<section class="contact" {...storyblokEditable(blok)}>
  <div class="content text-container-base py-16">
    <RichTextRenderer
      content={blok.content}
      resolver={(blok) => {
        return {
          component: StoryblokComponent,
          props: { blok }
        };
      }}
    />
    <div>
      <form id="contact-form" class="mt-8 space-y-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <div class="space-y-2">
            <label for="prenom" class="text-base-900 font-display text-sm font-medium uppercase">
              Prénom*
            </label>
            <input
              type="text"
              id="prenom"
              name="fi-sender-firstName"
              class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
              required
            />
          </div>
          <div class="space-y-2">
            <label for="nom" class="text-base-900 font-display text-sm font-medium uppercase">
              Nom*
            </label>
            <input
              type="text"
              id="nom"
              name="fi-sender-lastName"
              class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
              required
            />
          </div>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <div class="space-y-2">
            <label for="email" class="text-base-900 font-display text-sm font-medium uppercase">
              Email*
            </label>
            <input
              type="email"
              id="email"
              name="fi-sender-email"
              class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
              required
            />
          </div>
          <div class="space-y-2">
            <label for="telephone" class="text-base-900 font-display text-sm font-medium uppercase">
              Téléphone*
            </label>
            <input
              type="text"
              id="telephone"
              name="fi-text-phone"
              class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
              required
            />
          </div>
        </div>
        <div class="space-y-2">
          <label for="message" class="text-base-900 font-display text-sm font-medium uppercase">
            Message*
          </label>
          <textarea
            id="message"
            name="fi-text-message"
            rows="6"
            class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
            placeholder="Bonjour, je souhaite prendre rendez-vous. Voici les détails de ma demande : ..."
            required></textarea>
        </div>
        <button data-btn-hover="" class="btnPilates mx-auto">
          <div class="btn__bg"></div>
          <div class="btn__circle-wrap">
            <div class="btn__circle">
              <div class="before__100"></div>
            </div>
          </div>
          <div class="btn__text">
            <p class="btn-text-p">Envoyer</p>
          </div>
        </button>
      </form>
      <p id="form-status" class="mt-4 text-sm"></p>
    </div>
  </div>
  <div class="image">
    <Image
      src={blok.image?.filename}
      alt={blok.image?.alt}
      width={width}
      height={height}
      class="focal h-full max-h-none w-full object-cover"
    />
  </div>
</section>

<style>
  .btnPilates {
    cursor: pointer;
    border-radius: 1em;
    border-radius: calc(var(--btn-height) * 0.5);
    grid-template-rows: auto auto;
    grid-template-columns: 1fr 1fr;
    grid-auto-columns: 1fr;
    justify-content: center;
    align-items: center;
    height: 3em;
    padding-left: 1.25em;
    padding-right: 1.25em;
    text-decoration: none;
    display: flex;
    position: relative;
    width: fit-content;
  }

  .btn__text {
    color: var(--color-white);
    justify-content: flex-start;
    align-items: center;
    display: flex;
    position: relative;
    transition: color 0.7s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .btn-text-p {
    color: currentColor;
    white-space: nowrap;
    margin-block: 0;
    padding-bottom: 0.05em;
    font-size: 1em;
    font-weight: 500;
    line-height: 1.2;
  }

  .btn__bg {
    background-color: var(--color-lavande);
    border-radius: 1.5em;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .btn__image {
    border-radius: 50%;
    width: 2.25em;
    height: 2.25em;
    margin-left: -0.75em;
    margin-right: 0.5em;
    position: relative;
    overflow: hidden;
  }

  .img__founder {
    object-fit: cover;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .btn__circle-wrap {
    border-radius: 1.5em;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
  }

  .btn__circle {
    pointer-events: none;
    background-color: var(--color-atoll);
    border-radius: 50%;
    width: 100%;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transition:
      transform 0.7s cubic-bezier(0.625, 0.05, 0, 1),
      background-color 0.4s cubic-bezier(0.625, 0.05, 0, 1);
    transform: translate(-50%, -50%) scale(0) rotate(0.001deg);
    background-color: var(--color-atoll);
  }

  .before__100 {
    padding-top: 100%;
    display: block;
  }

  .btnPilates .btn__text {
    transition: color 0.7s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .btnPilates:hover .btn__circle {
    transform: translate(-50%, -50%) scale(1) rotate(0.001deg);
  }

  /* SOFT VARIANT */
  .btnPilates[soft] .btn__text {
    color: var(--color-marron);
  }

  .btnPilates[soft] .btn__bg {
    background-color: var(--color-pastel);
  }

  .btnPilates[soft] .btn__circle {
    background-color: var(--color-jaune);
  }
  /* INVERT VARIANT */
  .btnPilates[invert] .btn__text {
    color: var(--color-white);
  }

  .btnPilates[invert] .btn__bg {
    background-color: var(--color-atoll);
  }

  .btnPilates[invert] .btn__circle {
    background-color: var(--color-lavande);
  }
  /* ACCENT VARIANT */
  .btnPilates[accent] .btn__text {
    color: var(--color-marron);
  }

  .btnPilates[accent] .btn__bg {
    background-color: var(--color-jaune);
  }

  .btnPilates[accent] .btn__circle {
    background-color: var(--color-corail);
  }
</style>

<script>
  function initDirectionalButtonHover() {
    // Button hover animation
    document.querySelectorAll("[data-btn-hover]").forEach((button) => {
      button.addEventListener("mouseenter", handleHover);
      button.addEventListener("mouseleave", handleHover);
    });

    function handleHover(event) {
      const button = event.currentTarget;
      const buttonRect = button.getBoundingClientRect();

      // Get the button's dimensions and center
      const buttonWidth = buttonRect.width;
      const buttonHeight = buttonRect.height;
      const buttonCenterX = buttonRect.left + buttonWidth / 2;
      const buttonCenterY = buttonRect.top + buttonHeight / 2;

      // Calculate mouse position
      const mouseX = event.clientX;
      const mouseY = event.clientY;

      // Offset from the top-left corner in percentage
      const offsetXFromLeft = ((mouseX - buttonRect.left) / buttonWidth) * 100;
      const offsetYFromTop = ((mouseY - buttonRect.top) / buttonHeight) * 100;

      // Offset from the center in percentage
      let offsetXFromCenter = ((mouseX - buttonCenterX) / (buttonWidth / 2)) * 50;

      // Convert to absolute values
      offsetXFromCenter = Math.abs(offsetXFromCenter);

      // Update position and size of .btn__circle
      const circle = button.querySelector(".btn__circle");
      if (circle) {
        circle.style.left = `${offsetXFromLeft.toFixed(1)}%`;
        circle.style.top = `${offsetYFromTop.toFixed(1)}%`;
        circle.style.width = `${115 + offsetXFromCenter.toFixed(1) * 2}%`;
      }
    }
  }

  // Initialize Directional Button Hover
  document.addEventListener("DOMContentLoaded", function () {
    initDirectionalButtonHover();
  });
</script>

<script>
  function setImageHeight() {
    const contentHeight = document.querySelector(".content")?.clientHeight;
    const image = document.querySelector(".image");
    if (image) {
      image.style.height = `${contentHeight}px`;
    }
  }

  // Run on initial load
  setImageHeight();

  // Run on resize
  window.addEventListener("resize", setImageHeight);
</script>

<style define:vars={{ focalPointX, focalPointY }}>
  .contact {
    display: grid;
    grid-template-columns: 60% 1fr;
    gap: 0;
  }

  .image {
    max-height: none;
  }

  .focal {
    object-position: calc(var(--focalPointX) * 1%) calc(var(--focalPointY) * 1%);
  }

  /* On mobile, stack vertically */
  @media (max-width: 1024px) {
    .contact {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }
    .image {
      max-height: 50vh;
    }
  }

  /* Ensure image fills its container while maintaining aspect ratio */
  .contact > :first-child img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script src="https://forminit.com/sdk/v1/forminit.js" is:raw></script>
<script is:inline>
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initForminit);
  } else {
    initForminit();
  }

  function initForminit() {
    if (typeof window.Forminit === "undefined") {
      console.error("Forminit SDK not loaded. Check network or ad-blockers.");
      return;
    }
    const forminit = new window.Forminit();
    document.getElementById("contact-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const statusEl = document.getElementById("form-status");

      const { data, redirectUrl, error } = await forminit.submit("XXXXXX", new FormData(e.target));

      if (error) {
        statusEl.textContent = error.message;
        statusEl.style.color = "#ef4444";
        return;
      }

      statusEl.textContent = "Message envoyé avec succ\u00e8s !";
      statusEl.style.color = "#16a34a";
      e.target.reset();
    });
  }
</script>

---
import { storyblokEditable } from "@storyblok/astro";
import Button from "./Button.astro";

const days = ["LUNDI", "MARDI", "MERCREDI", "JEUDI", "VENDREDI"];

const { blok } = Astro.props;

const classes = [blok.lundi, blok.mardi, blok.mercredi, blok.jeudi, blok.vendredi];
---

<section class="planning p-4 md:p-8" {...storyblokEditable(blok)}>
  <div class="mx-auto grid max-w-400 grid-cols-1 gap-8 xl:grid-cols-5 xl:gap-4">
    {
      days.map((day, index) => (
        <div class="gap-stack-md flex flex-col">
          <div class="border-outline mb-4 border-b pb-4">
            <p class="text-atoll text-3xl">{day}</p>
          </div>
          <div class="flex flex-col gap-4">
            {classes[index].map((creneau) => (
              <div class="bg-jaune rounded-xl p-4 transition-all duration-300 hover:shadow-sm">
                <span class="horaires">{creneau.time}</span>
                <h3 class="cours">{creneau.name}</h3>
                <p class="coach">{creneau.coach}</p>

                <div class="mt-2 flex items-center justify-between">
                  {creneau.opentoresa && (
                    <div>
                      <button
                        type="button"
                        data-btn-hover=""
                        class="btnPilates reserve-btn mx-auto"
                        invert="true"
                        data-creneau-day={day}
                        data-creneau-time={creneau.time}
                        data-creneau-cours={creneau.name}>
                        <div class="btn__bg" />
                        <div class="btn__circle-wrap">
                          <div class="btn__circle">
                            <div class="before__100" />
                          </div>
                        </div>
                        <div class="btn__text">
                          <p class="btn-text-p">Réserver</p>
                        </div>
                      </button>
                    </div>
                  )}
                  {!creneau.opentoresa && (
                    <span class="rounded-full bg-gray-300/50 px-2 py-0.5 text-[15px] font-bold tracking-wider uppercase xl:text-[10px]">
                      Complet
                    </span>
                  )}

                  {creneau.niveau && (
                    <span class="bg-primary/15 rounded-full px-2 py-0.5 text-[15px] font-bold tracking-wider uppercase xl:text-[10px]">
                      {creneau.niveau}
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<!-- Reservation Modal Overlay -->
<div id="reserve-modal" class="reserve-modal hidden">
  <div class="reserve-modal-backdrop" id="reserve-modal-backdrop"></div>
  <div class="reserve-modal-content">
    <button type="button" class="reserve-modal-close" id="reserve-modal-close">&times;</button>
    <h2 class="text-atoll font-heading mb-6 text-3xl">Réserver ce créneau</h2>
    <p class="reserve-creneau-info mb-4 text-lg"></p>
    <form id="reserve-form" class="space-y-4">
      <div class="space-y-2">
        <label for="reserve-name" class="text-base-900 font-display text-sm font-medium uppercase">
          Nom et prénom*
        </label>
        <input
          type="text"
          id="reserve-name"
          name="name"
          class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
          required
        />
      </div>
      <div class="space-y-2">
        <label for="reserve-email" class="text-base-900 font-display text-sm font-medium uppercase">
          Email*
        </label>
        <input
          type="email"
          id="reserve-email"
          name="email"
          class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
          required
        />
      </div>
      <div class="space-y-2">
        <label for="reserve-phone" class="text-base-900 font-display text-sm font-medium uppercase">
          Téléphone*
        </label>
        <input
          type="tel"
          id="reserve-phone"
          name="phone"
          class="border-base-200 bg-base-50 text-base-900 placeholder:text-base-400 focus:border-base-500 focus:ring-base-500 w-full rounded-lg border px-4 py-3 transition-all duration-200 focus:ring-1 focus:outline-none"
          required
        />
      </div>
      <p id="reserve-form-status" class="min-h-[1.5rem] text-sm"></p>
      <button type="submit" data-btn-hover="" class="btnPilates mx-auto">
        <div class="btn__bg"></div>
        <div class="btn__circle-wrap">
          <div class="btn__circle">
            <div class="before__100"></div>
          </div>
        </div>
        <div class="btn__text">
          <p class="btn-text-p">Envoyer</p>
        </div>
      </button>
    </form>
  </div>
</div>

<style>
  .btnPilates {
    cursor: pointer;
    border-radius: 1em;
    border-radius: calc(var(--btn-height) * 0.5);
    grid-template-rows: auto auto;
    grid-template-columns: 1fr 1fr;
    grid-auto-columns: 1fr;
    justify-content: center;
    align-items: center;
    height: 2em;
    padding-left: 1em;
    padding-right: 1em;
    text-decoration: none;
    display: flex;
    position: relative;
    width: fit-content;
  }

  .btn__text {
    color: var(--color-white);
    justify-content: flex-start;
    align-items: center;
    display: flex;
    position: relative;
    transition: color 0.7s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .btn-text-p {
    color: currentColor;
    white-space: nowrap;
    margin-block: 0;
    padding-bottom: 0.05em;
    font-size: 1em;
    font-weight: 500;
    line-height: 1.2;
  }

  .btn__bg {
    background-color: var(--color-lavande);
    border-radius: 1.5em;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .btn__image {
    border-radius: 50%;
    width: 2.25em;
    height: 2.25em;
    margin-left: -0.75em;
    margin-right: 0.5em;
    position: relative;
    overflow: hidden;
  }

  .img__founder {
    object-fit: cover;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .btn__circle-wrap {
    border-radius: 1.5em;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
  }

  .btn__circle {
    pointer-events: none;
    background-color: var(--color-atoll);
    border-radius: 50%;
    width: 100%;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transition:
      transform 0.7s cubic-bezier(0.625, 0.05, 0, 1),
      background-color 0.4s cubic-bezier(0.625, 0.05, 0, 1);
    transform: translate(-50%, -50%) scale(0) rotate(0.001deg);
    background-color: var(--color-atoll);
  }

  .before__100 {
    padding-top: 100%;
    display: block;
  }

  .btnPilates .btn__text {
    transition: color 0.7s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .btnPilates:hover .btn__circle {
    transform: translate(-50%, -50%) scale(1) rotate(0.001deg);
  }

  /* SOFT VARIANT */
  .btnPilates[soft] .btn__text {
    color: var(--color-marron);
  }

  .btnPilates[soft] .btn__bg {
    background-color: var(--color-pastel);
  }

  .btnPilates[soft] .btn__circle {
    background-color: var(--color-jaune);
  }
  /* INVERT VARIANT */
  .btnPilates[invert] .btn__text {
    color: var(--color-white);
  }

  .btnPilates[invert] .btn__bg {
    background-color: var(--color-atoll);
  }

  .btnPilates[invert] .btn__circle {
    background-color: var(--color-lavande);
  }
  /* ACCENT VARIANT */
  .btnPilates[accent] .btn__text {
    color: var(--color-marron);
  }

  .btnPilates[accent] .btn__bg {
    background-color: var(--color-jaune);
  }

  .btnPilates[accent] .btn__circle {
    background-color: var(--color-corail);
  }
</style>

<script>
  function initDirectionalButtonHover() {
    // Button hover animation
    document.querySelectorAll("[data-btn-hover]").forEach((button) => {
      button.addEventListener("mouseenter", handleHover);
      button.addEventListener("mouseleave", handleHover);
    });

    function handleHover(event) {
      const button = event.currentTarget;
      const buttonRect = button.getBoundingClientRect();

      // Get the button's dimensions and center
      const buttonWidth = buttonRect.width;
      const buttonHeight = buttonRect.height;
      const buttonCenterX = buttonRect.left + buttonWidth / 2;
      const buttonCenterY = buttonRect.top + buttonHeight / 2;

      // Calculate mouse position
      const mouseX = event.clientX;
      const mouseY = event.clientY;

      // Offset from the top-left corner in percentage
      const offsetXFromLeft = ((mouseX - buttonRect.left) / buttonWidth) * 100;
      const offsetYFromTop = ((mouseY - buttonRect.top) / buttonHeight) * 100;

      // Offset from the center in percentage
      let offsetXFromCenter = ((mouseX - buttonCenterX) / (buttonWidth / 2)) * 50;

      // Convert to absolute values
      offsetXFromCenter = Math.abs(offsetXFromCenter);

      // Update position and size of .btn__circle
      const circle = button.querySelector(".btn__circle");
      if (circle) {
        circle.style.left = `${offsetXFromLeft.toFixed(1)}%`;
        circle.style.top = `${offsetYFromTop.toFixed(1)}%`;
        circle.style.width = `${115 + offsetXFromCenter.toFixed(1) * 2}%`;
      }
    }
  }

  // Initialize Directional Button Hover
  document.addEventListener("DOMContentLoaded", function () {
    initDirectionalButtonHover();
  });
</script>

<style>
  @reference "../../styles/global.css";
  .horaires {
    @apply text-2xl font-bold;
  }
  .cours {
    @apply mt-1 text-4xl;
  }
  .coach {
    @apply text-lg;
  }
  .reserve-modal {
    @apply fixed inset-0 z-50 flex items-center justify-center;
  }
  .reserve-modal-backdrop {
    @apply bg-atoll/70 absolute inset-0;
  }
  .reserve-modal-content {
    @apply relative mx-4 max-h-[90vh] w-full max-w-md overflow-y-auto rounded-xl bg-white p-8;
  }
  .reserve-modal-close {
    @apply text-atoll hover:text-lavande absolute top-4 right-4 cursor-pointer border-none bg-transparent text-2xl font-bold;
  }
  #reserve-modal.hidden {
    @apply hidden;
  }
  #reserve-modal:not(.hidden) {
    @apply flex;
  }
</style>

<script>
  function openReserveModal(day, time, cours) {
    const modal = document.getElementById("reserve-modal");
    const infoEl = document.querySelector(".reserve-creneau-info");
    const statusEl = document.getElementById("reserve-form-status");

    if (infoEl) {
      infoEl.textContent = `Créneau: ${day} à ${time} - ${cours}`;
    }
    if (statusEl) {
      statusEl.textContent = "";
    }
    if (modal) {
      modal.classList.remove("hidden");
      modal.dataset.day = day;
      modal.dataset.time = time;
      modal.dataset.cours = cours;
    }
  }

  function closeReserveModal() {
    const modal = document.getElementById("reserve-modal");
    if (modal) {
      modal.classList.add("hidden");
    }
  }

  function initReserveModal() {
    document.querySelectorAll(".reserve-btn").forEach((btn) => {
      btn.addEventListener("click", function (e) {
        const day = this.dataset.creneauDay;
        const time = this.dataset.creneauTime;
        const cours = this.dataset.creneauCours;
        openReserveModal(day, time, cours);
      });
    });

    const closeBtn = document.getElementById("reserve-modal-close");
    if (closeBtn) {
      closeBtn.addEventListener("click", closeReserveModal);
    }

    const backdrop = document.getElementById("reserve-modal-backdrop");
    if (backdrop) {
      backdrop.addEventListener("click", closeReserveModal);
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeReserveModal();
      }
    });

    const form = document.getElementById("reserve-form");
    if (form) {
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        const statusEl = document.getElementById("reserve-form-status");
        const modal = document.getElementById("reserve-modal");

        const formData = new FormData(e.target);
        const data = {
          name: formData.get("name"),
          email: formData.get("email"),
          phone: formData.get("phone"),
          day: modal.dataset.day,
          time: modal.dataset.time,
          cours: modal.dataset.cours
        };

        try {
          const response = await fetch("/api/reserve", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
          });

          const result = await response.json();

          if (!response.ok) {
            if (statusEl) {
              statusEl.textContent = result.error || "Erreur lors de l'envoi";
              statusEl.style.color = "#ef4444";
            }
            return;
          }

          window.location.href = "https://backoffice.bsport.io/login/customer?membership=4477";
        } catch (err) {
          if (statusEl) {
            statusEl.textContent = "Erreur de connexion";
            statusEl.style.color = "#ef4444";
          }
        }
      });
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    initReserveModal();
  });
</script>

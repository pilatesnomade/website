---
import { Image, inferRemoteSize } from "astro:assets";
import { storyblokEditable } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import RichTextRenderer from "storyblok-rich-text-astro-renderer/RichTextRenderer.astro";

let focalPointX = 50;
let focalPointY = 50;
let currentwidth = 0;
let currentheight = 0;
const { blok } = Astro.props;
if (blok.image.id) {
  const posX = blok.image?.focus?.split(":")[0].split("x")[0] || "50";
  const posY = blok.image?.focus?.split(":")[0].split("x")[1] || "50";
  const { width, height } = await inferRemoteSize(blok.image?.filename);
  currentwidth = width;
  currentheight = height;
  focalPointX = (parseInt(posX) / width) * 100;
  focalPointY = (parseInt(posY) / height) * 100;
}
---

<section class={`split-layout ${blok.margin ? "mt-16" : ""}`} {...storyblokEditable(blok)}>
  <div class="image">
    {
      blok.image.id && (
        <Image
          src={blok.image?.filename}
          alt={blok.image?.alt}
          width={currentwidth}
          height={currentheight}
          layout="constrained"
          class="focal h-full w-full object-cover"
        />
      )
    }
  </div>
  <div class="content text-container-base">
    <RichTextRenderer
      content={blok.content}
      resolver={(blok) => {
        return {
          component: StoryblokComponent,
          props: { blok }
        };
      }}
    />
  </div>
</section>

<script>
  function setImageHeight() {
    const splitSections = document.querySelectorAll(".split-layout");
    splitSections.forEach((section) => {
      const contentHeight = section.querySelector(".content > div")?.clientHeight;
      const image = section.querySelector(".image");
      if (image) {
        image.style.height = `calc(${contentHeight}px + 8rem)`;
      }
    });
  }

  // Run on initial load
  setImageHeight();

  // Run on resize
  window.addEventListener("resize", setImageHeight);
</script>

<style define:vars={{ focalPointX, focalPointY }}>
  .split-layout {
    display: grid;
    gap: 0;
  }

  .image {
    max-height: none;
  }

  .focal {
    object-position: calc(var(--focalPointX) * 1%) calc(var(--focalPointY) * 1%);
  }

  /* On mobile, stack vertically */
  @media (max-width: 1024px) {
    .split-layout {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }
    .image {
      max-height: 50vh;
    }
  }

  /* Ensure image fills its container while maintaining aspect ratio */
  .split-layout > :first-child img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  function setImageHeight() {
    const contentHeight = document.querySelector(".content")?.clientHeight;
    const image = document.querySelector(".image");
    if (image) {
      image.style.height = `${contentHeight}px`;
    }
  }

  // Run on initial load
  setImageHeight();

  // Run on resize
  window.addEventListener("resize", setImageHeight);
</script>

<style>
  .text-image {
    display: grid;
    grid-template-columns: 40% 1fr;
    gap: 0;
  }

  .image {
    max-height: none;
  }

  /* On mobile, stack vertically */
  @media (max-width: 639px) {
    .text-image {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }
    .image {
      max-height: 50vh;
    }
  }

  /* Ensure image fills its container while maintaining aspect ratio */
  .text-image > :first-child img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
